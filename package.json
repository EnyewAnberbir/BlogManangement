{
  "name": "blogmanangement",
  "version": "1.0.0",
  "description": "Full-stack blog platform with authentication and post management APIs.",
  "main": "appi/index.js",
  "scripts": {
    "start": "node appi/index.js",
    "test": "node --test tests/*.test.js",
    "quality:boilerplate": "node scripts/boilerplate-filter.js",
    "quality:boilerplate:strict": "powershell -Command \"$env:BOILERPLATE_STRICT='true'; node scripts/boilerplate-filter.js\"",
    "quality:ready": "node scripts/ready-check.js",
    "lint": "eslint \"**/*.js\"",
    "format": "prettier --write \"**/*.{js,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{js,json,md,css}\""
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "date-fns": "^3.6.0",
    "dotenv": "^17.4.2",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.3.3",
    "multer": "^1.4.5-lts.1",
    "nodemon": "^3.1.0",
    "react-quill": "^2.0.0",
    "react-router-dom": "^6.23.0",
    "supertest": "^7.1.4"
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "eslint": "^9.28.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "prettier": "^3.5.3"
  },
  "keywords": []
}
